{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors https://thepines.casa http://homeassistant.local:8123" }
      ]
    }
  ],
  "redirects": [
    { "source": "/package-lock.json", "destination": "/", "permanent": false },
    { "source": "/README.md", "destination": "/", "permanent": false }
  ]
}
